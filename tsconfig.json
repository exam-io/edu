{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "ignoreDeprecations": "6.0",
    "allowJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["resources/js/*"],
      "@app/*": ["resources/js/app/*"],
      "@modules/*": ["resources/js/modules/*"],
      "@shared/*": ["resources/js/shared/*"],
      "@components/*": ["resources/js/components/*"],
      "@layouts/*": ["resources/js/layouts/*"],
      "@providers/*": ["resources/js/providers/*"],
      "@hooks/*": ["resources/js/hooks/*"],
      "@services/*": ["resources/js/services/*"],
      "@stores/*": ["resources/js/stores/*"],
      "@themes/*": ["resources/js/themes/*"],
      "@locales/*": ["resources/js/locales/*"],
      "@routes/*": ["resources/js/routes/*"]
    }
  },
  "include": ["resources/js/**/*.ts", "resources/js/**/*.tsx", "vite.config.js", "eslint.config.js"]
}
